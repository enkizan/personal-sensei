# Copy this file to .env.local and fill in real values
# .env.local is gitignored and must never be committed

# Anthropic API key — required for lesson generation and chat
ANTHROPIC_API_KEY=sk-ant-...

# Passcode to gate access to the app
PASSCODE=your-passcode-here

# Postgres connection string
# Local dev (docker compose): postgresql://postgres:postgres@localhost:10001/japanese_platform
# Production (Neon or other): postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:10001/japanese_platform
